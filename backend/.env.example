# === DATABASE ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=pixeladvant
DB_PASSWORD=your_strong_password_here
DB_NAME=pixeladvant_db

# === JWT ===
JWT_SECRET=your_jwt_secret_key_min_32_chars_here
JWT_EXPIRES_IN=7d

# === SERVER ===
PORT=5000
FRONTEND_URL=http://localhost:5173

# === ADMIN SEED (used by setup.js) ===
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@pixeladvant.com
ADMIN_PASSWORD=Admin@2025!

# === EMAIL (Gmail SMTP – same config as pixel_advant_be hr-backend) ===
# Use a Gmail App Password (not your account password).
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=pixeladvant@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=pixeladvant@gmail.com
# Address that receives admin notifications for every contact form submission
ADMIN_NOTIFICATION_EMAIL=pixeladvant@gmail.com
