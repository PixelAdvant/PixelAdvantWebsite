# ── DATABASE ───────────────────────────────────────────────────
DB_NAME=pixeladvant_db
DB_USER=pixeladvant
DB_PASSWORD=change_this_strong_password

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=7d

# ── SERVER ─────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=https://pixeladvant.com

# ── EMAIL ──────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=pixeladvant@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=pixeladvant@gmail.com
ADMIN_NOTIFICATION_EMAIL=pixeladvant@gmail.com

# ── ADMIN SEED ─────────────────────────────────────────────────
# Used once: docker compose exec backend node database/setup.js
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@pixeladvant.com
ADMIN_PASSWORD=change_this_strong_password
